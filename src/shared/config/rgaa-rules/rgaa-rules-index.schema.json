{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://baldr.dev/schemas/rgaa-rules-index-1.0.json",
  "title": "RGAA Rules Index",
  "description": "Manifest ruleId -> chemin relatif du fichier de règle (v1.0).",
  "type": "object",
  "additionalProperties": false,
  "required": ["rules"],
  "properties": {
    "$schema": { "type": "string" },
    "rules": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^\\./.+\\.json$" }
    }
  }
}
