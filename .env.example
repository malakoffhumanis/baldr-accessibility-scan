# ============================================================================
# BALDR — environment configuration
# Copy to `.env` and adjust. Values shown are the defaults unless noted.
# All variables are validated at startup (src/shared/config/config.ts);
# an invalid or missing required value aborts boot with an explicit message.
# ============================================================================

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
# Server timeout in ms — caps max request duration (default: 300000 = 5 min).
# SERVER_TIMEOUT_MS=300000

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave empty to block all cross-origin requests (recommended default).
# Example: CORS_ORIGIN=https://front.example.com,https://admin.example.com
CORS_ORIGIN=

# ─── Authentication (REQUIRED — no default) ─────────────────────────────────
# API keys protecting the audit endpoint (POST /api/v1/journey).
# Comma-separated list; each entry is `id:secret`. The `id` is a public label
# used in logs/metrics for attribution (never the secret); a bare `secret`
# without an id gets a derived one (key-<hash>). Requests must send a matching
# secret in the `X-API-Key` header (constant-time compare) or get 401.
# MANDATORY: at least one entry. An empty/unset value aborts startup —
# unauthenticated ("openbar") mode is no longer supported. The /health probe
# is never protected.
API_KEYS=client-a:change-me-long-random-secret,client-b:another-long-secret

# ─── LLM Provider (OpenAI-compatible) — optional, enables AI-enriched analysis ─
# Setting LLM_PROVIDER_API_KEY enables the provider. ENDPOINT is the
# OpenAI-compatible base URL (defaults to https://api.openai.com/v1).
# LLM_PROVIDER_API_KEY=your-api-key-here
# LLM_PROVIDER_ENDPOINT=https://api.openai.com/v1
# Model to use (default: see DEFAULT_LLM_MODEL in config).
# LLM_PROVIDER_MODEL=gpt-4o
# Override the model context window (tokens) if auto-detection is wrong.
# LLM_CONTEXT_LIMIT=128000

# ─── Outbound proxy ──────────────────────────────────────────────────────────
# Used for both the LLM provider and audited-page traffic. The first set among
# HTTPS_PROXY / https_proxy / HTTP_PROXY / http_proxy wins.
# HTTPS_PROXY=http://proxy.example.com:8080

# ─── Browser (Puppeteer) ─────────────────────────────────────────────────────
# Run with a visible browser window (ignored in production — always headless).
# PUPPETEER_HEADFUL=true
# Path to a custom Chromium/Chrome binary instead of the bundled one.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ─── Reports & metadata ──────────────────────────────────────────────────────
# Output directory for generated reports (default: ./reports).
# REPORTS_DIR=./reports
# Version string surfaced by /health (defaults to package.json version).
# APP_VERSION=1.0.0

# ─── API docs ────────────────────────────────────────────────────────────────
# Expose Swagger UI at /api/v1/docs (disabled by default; off in production).
# EXPOSE_API_DOCS=true

# ─── Security & debug toggles ────────────────────────────────────────────────
# Enable dangerous Puppeteer flags (--disable-web-security,
# --ignore-certificate-errors). Only for auditing sites with self-signed certs
# or CORS issues. IGNORED when NODE_ENV=production (security stays on, a warning
# is logged) — it only takes effect in non-production environments.
# BALDR_ALLOW_INSECURE=true

# Anti-SSRF allowlist — comma-separated hostnames that bypass the private/
# internal-IP blocking, for DELIBERATELY auditing internal apps that resolve to
# a private IP (corporate split-horizon DNS). Exact host or `*.suffix` wildcard.
# Only these hosts are relaxed; every other host (and the protocol check) stays
# protected. localhost/metadata stay blocked even if listed.
# Example: BALDR_SSRF_ALLOW_HOSTS=mon-compte.example.com,*.intranet.corp
# BALDR_SSRF_ALLOW_HOSTS=

# Capture the DOM + a base64 screenshot on journey errors (also written under
# reports/journey-error-*.jpg). DISABLED by default to avoid leaking sensitive
# page content. When enabled, password/sensitive input values are stripped.
# BALDR_DEBUG_ERROR_CAPTURE=true

# ─── Business DOM selectors (target-framework specific) ─────────────────────
# Teach the journey engine a back-office framework's own conventions so it can
# drive proprietary AJAX menus. All empty by default — the engine then relies
# only on universal web conventions (roles, data-action/target, data-testid…).
# Comma-separated. Keep these in your private .env, NOT in source control.
#
# Extra CSS selectors added to the clickable-candidate query:
# BUSINESS_CLICKABLE_SELECTORS=[data-ajax-code],[data-ajax]
# CSS classes that mark a menu CONTAINER (vs a clickable leaf):
# BUSINESS_CONTAINER_CLASSES=menu-folder
# Attribute=value pairs that mark a menu CONTAINER:
# BUSINESS_CONTAINER_ATTRIBUTES=data-menu-type=submenu
# Attribute names (priority order) treated as a stable/unique selector:
# BUSINESS_STABLE_ATTRIBUTES=data-ajax-code
# Attribute names whose mere presence marks an AJAX trigger:
# BUSINESS_AJAX_TRIGGER_ATTRIBUTES=data-ajax,data-ajax-code

# ─── LLM record / replay (testing & debugging) ──────────────────────────────
# Record live LLM responses to disk for later deterministic replay.
# BALDR_LLM_RECORD=true
# Replay a previously recorded run by its id (no live LLM calls are made).
# BALDR_LLM_REPLAY=<run-id>
